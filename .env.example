# Copy this file to .env and fill in the values. NEVER commit .env.

# --- Anthropic (required, also for --dry-run since scoring always runs) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Telegram delivery (required only for real delivery; not for --dry-run) ---
# Create a bot with @BotFather to get the token. See README for how to get the chat id.
TELEGRAM_BOT_TOKEN=123456789:AA-your-bot-token-here
TELEGRAM_CHAT_ID=123456789

# --- NCBI E-utilities etiquette ---
# Email is recommended (NCBI asks every request identify itself). API key is optional
# and raises the rate limit from 3 to 10 requests/second.
EUTILS_EMAIL=you@example.com
# NCBI_API_KEY=your-optional-ncbi-api-key
